            },
        ];

        // Sample groups
        this.groups = [
            { id: '1', name: 'College Tennis Coaches', category: 'college', memberCount: 156, description: 'Network for college tennis coaches' },
            { id: '2', name: 'Junior Development', category: 'juniors', memberCount: 243, description: 'Coaches working with junior players' },
            { id: '3', name: 'Pro Player Development', category: 'pro', memberCount: 89, description: 'Coaches working with professional players' },
        ];

        // Sample opportunities
        this.opportunities = [
            {
                id: '1',
                type: 'looking-for-players',
                title: 'Looking for UTR 11+ Players',
                description: 'D1 university program seeking talented players for Fall 2026',
                level: 'UTR 11-13',
                location: 'California, USA',
                active: true,
                createdAt: new Date(),
            },
        ];
    }

    // Exercises
    getExercises() { return this.exercises; }
    getExercise(id: string) { return this.exercises.find(e => e.id === id); }
    addExercise(exercise: Exercise) { this.exercises.push(exercise); return exercise; }
    updateExercise(id: string, data: Partial<Exercise>) {
        const index = this.exercises.findIndex(e => e.id === id);
        if (index !== -1) {
            this.exercises[index] = { ...this.exercises[index], ...data };
            return this.exercises[index];
        }
        return null;
    }
    deleteExercise(id: string) {
        this.exercises = this.exercises.filter(e => e.id !== id);
    }

    // Sessions
    getSessions() { return this.sessions; }
    getSession(id: string) { return this.sessions.find(s => s.id === id); }
    addSession(session: Session) { this.sessions.push(session); return session; }
    updateSession(id: string, data: Partial<Session>) {
        const index = this.sessions.findIndex(s => s.id === id);
        if (index !== -1) {
            this.sessions[index] = { ...this.sessions[index], ...data };
            return this.sessions[index];
        }
        return null;
    }
    deleteSession(id: string) {
        this.sessions = this.sessions.filter(s => s.id !== id);
    }

    // Calendar
    getCalendarEvents() { return this.calendar; }
    getCalendarEvent(id: string) { return this.calendar.find(e => e.id === id); }
    addCalendarEvent(event: CalendarEvent) { this.calendar.push(event); return event; }
    updateCalendarEvent(id: string, data: Partial<CalendarEvent>) {
        const index = this.calendar.findIndex(e => e.id === id);
        if (index !== -1) {
            this.calendar[index] = { ...this.calendar[index], ...data };
            return this.calendar[index];
        }
        return null;
    }
    deleteCalendarEvent(id: string) {
        this.calendar = this.calendar.filter(e => e.id !== id);
    }

    // Playlists
    getPlaylists() { return this.playlists; }
    getPlaylist(id: string) { return this.playlists.find(p => p.id === id); }
    addPlaylist(playlist: Playlist) { this.playlists.push(playlist); return playlist; }
    updatePlaylist(id: string, data: Partial<Playlist>) {
        const index = this.playlists.findIndex(p => p.id === id);
        if (index !== -1) {
            this.playlists[index] = { ...this.playlists[index], ...data };
            return this.playlists[index];
        }
        return null;
    }
    deletePlaylist(id: string) {
        this.playlists = this.playlists.filter(p => p.id !== id);
    }

    // Teams
    getTeams() { return this.teams; }
    getTeam(id: string) { return this.teams.find(t => t.id === id); }
    addTeam(team: Team) { this.teams.push(team); return team; }

    // Messages
    getMessages() { return this.messages; }
    addMessage(message: Message) { this.messages.push(message); return message; }

    // Groups
    getGroups() { return this.groups; }
    getGroup(id: string) { return this.groups.find(g => g.id === id); }

    // Opportunities
    getOpportunities() { return this.opportunities; }
    addOpportunity(opp: Opportunity) { this.opportunities.push(opp); return opp; }
}

export const dataStore = new DataStore();
